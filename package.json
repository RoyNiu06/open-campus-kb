{
  "name": "open-campus-kb",
  "version": "2.4.0-example",
  "description": "Open-source framework for reviewed, source-grounded campus knowledge bases and AI Q&A assistants.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "keywords": [
    "knowledge-base",
    "rag",
    "campus",
    "cloudflare-workers",
    "supabase",
    "pgvector"
  ],
  "scripts": {
    "check": "node --check worker/open-campus-worker.mjs",
    "seed:example": "node scripts/seed-example-documents.mjs",
    "check:release": "node scripts/check-release.mjs",
    "preview": "node scripts/serve-local.mjs",
    "app:dev": "next dev",
    "app:build": "next build",
    "pages:build": "next build && node scripts/prepare-next-pages.mjs",
    "dev": "wrangler dev --config wrangler.example.jsonc",
    "deploy": "wrangler deploy --config wrangler.example.jsonc"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^16.2.10",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.7.2",
    "wrangler": "^4.99.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
